# ─────────────────────────────────────────────────────────────
# AQI-MLOps environment template.
# Copy to .env and fill in real values. NEVER commit .env.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# --- OpenAQ API (register free key at https://explore.openaq.org/register) ---
OPENAQ_API_KEY=your_openaq_v3_key_here
OPENAQ_BASE_URL=https://api.openaq.org/v3

# --- Open-Meteo (no key required) ---
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# --- Postgres (app data + Airflow metadata) ---
POSTGRES_USER=aqi
POSTGRES_PASSWORD=aqi
POSTGRES_DB=aqi
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=change_me
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# --- Redis (Celery broker) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- Storage: local dir now, swap to gs://aqi-mlops-data at Week 3 ---
DATA_ROOT=/opt/airflow/data

# --- Target cities (comma-separated; start with Delhi only for Week 1) ---
CITIES=Delhi
